---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
---

<BaseLayout
  title="Pete McPherson — Portfolio (Placeholder)"
  description="Placeholder description for Pete McPherson’s minimal portfolio website."
>
  <section class="py-6 sm:py-10">
    <div class="flex flex-col gap-8">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-black/60">
          Placeholder label
        </p>
        <h1 class="mt-3 text-4xl font-bold leading-[0.95] sm:text-6xl">
          Pete McPherson <span class="text-accent">does bold work</span> with lots of
          white space.
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-black/70 sm:text-lg">
          Placeholder tagline. Replace this with a short sentence about what Pete does,
          who he helps, and what makes his work unique.
        </p>
      </div>

      <NewsletterForm />
    </div>
  </section>

  <section class="mt-14 border-t border-black/10 pt-12 sm:mt-20 sm:pt-16">
    <div class="grid gap-8 sm:grid-cols-3 sm:items-start">
      <div class="sm:col-span-2">
        <h2 class="text-2xl font-bold sm:text-3xl">A quick intro</h2>
        <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
          Placeholder intro paragraph. Add a concise overview of Pete’s background,
          accomplishments, and what he’s building right now.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
          Placeholder second paragraph. Use this space for a few highlights (e.g.
          focus areas, past roles, notable wins).
        </p>
      </div>

      <div class="sm:justify-self-end">
        <a
          href="/projects"
          class="inline-flex w-full items-center justify-center rounded-lg bg-black px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-white sm:w-auto"
        >
          See projects
        </a>
        <p class="mt-3 text-xs text-black/60">
          Placeholder note — add a small supporting line later.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

