---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
---

<BaseLayout
  title="Joseph muema — Portfolio (Placeholder)"
  description="Placeholder description for Joseph muema’s minimal portfolio website."
>
  <section class="py-10 sm:py-16">
    <div class="grid gap-10 sm:grid-cols-[minmax(0,1.6fr)_minmax(0,1fr)] sm:items-center">
      <div class="space-y-5">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-black/60">
          Placeholder label
        </p>
        <h1 class="text-4xl font-bold leading-[0.95] sm:text-6xl">
          Joseph muema <span class="text-accent">does bold work</span> with lots of
          white space.
        </h1>
        <p class="max-w-2xl text-base leading-relaxed text-black/70 sm:text-lg">
          Placeholder tagline. Replace this with a short sentence about what you do,
          who you help, and what makes your work unique.
        </p>
        <div class="mt-4 max-w-xl">
          <NewsletterForm />
        </div>
      </div>

      <div class="flex justify-center sm:justify-end">
        <div class="relative inline-block">
          <div class="absolute -inset-3 rounded-3xl border border-black/5"></div>
          <img
            src="/M.png"
            alt="Portrait or branding graphic for Joseph muema"
            class="relative z-10 w-full max-w-xs rounded-3xl border border-black/10 bg-white object-cover shadow-sm"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mt-12 border-t border-black/10 pt-10 sm:mt-16 sm:pt-14">
    <div class="grid gap-8 sm:grid-cols-3 sm:items-start">
      <div class="sm:col-span-2 space-y-3">
        <h2 class="text-2xl font-bold sm:text-3xl">A quick intro</h2>
        <p class="text-sm leading-relaxed text-black/70 sm:text-base">
          Placeholder intro paragraph. Add a concise overview of your background,
          accomplishments, and what you’re building right now.
        </p>
        <p class="text-sm leading-relaxed text-black/70 sm:text-base">
          Placeholder second paragraph. Use this space for a few highlights (e.g.
          focus areas, past roles, notable wins).
        </p>
      </div>

      <div class="sm:justify-self-end space-y-3">
        <a
          href="/projects"
          class="inline-flex w-full items-center justify-center rounded-lg bg-black px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-white sm:w-auto"
        >
          See projects
        </a>
        <p class="text-xs text-black/60">
          Placeholder note — add a small supporting line later.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

