---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
---

<BaseLayout
  title="Joseph muema — Portfolio (Placeholder)"
  description="Placeholder description for Joseph muema’s minimal portfolio website."
>
  <section class="py-10 sm:py-14">
    <div class="container-max grid gap-10 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)] lg:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-black/60">
          Portfolio of Joseph muema
        </p>
        <h1 class="mt-4 text-4xl font-bold leading-[0.95] sm:text-5xl md:text-6xl">
          Joseph muema <span class="text-accent">builds clean, bold</span> digital
          experiences.
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-black/70 sm:text-lg">
          Frontend developer and creative technologist. I design and build minimal,
          high-performance interfaces with a focus on clarity, speed, and good vibes.
        </p>

        <div class="mt-8 max-w-xl">
          <NewsletterForm />
        </div>
      </div>

      <div class="mx-auto w-full max-w-xs sm:max-w-sm">
        <div class="overflow-hidden rounded-2xl border border-black/10 bg-white shadow-sm">
          <img
            src="/M.png"
            alt="Portrait or branding graphic for Joseph muema"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mt-14 border-t border-black/10 pt-12 sm:mt-20 sm:pt-16">
    <div class="grid gap-8 sm:grid-cols-3 sm:items-start">
      <div class="sm:col-span-2">
        <h2 class="text-2xl font-bold sm:text-3xl">A quick intro</h2>
        <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
          Placeholder intro paragraph. Add a concise overview of Joseph’s background,
          accomplishments, and what he’s building right now.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
          Placeholder second paragraph. Use this space for a few highlights (e.g.
          focus areas, past roles, notable wins).
        </p>
      </div>

      <div class="sm:justify-self-end">
        <a
          href="/projects"
          class="inline-flex w-full items-center justify-center rounded-lg bg-black px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-white sm:w-auto"
        >
          See projects
        </a>
        <p class="mt-3 text-xs text-black/60">
          Placeholder note — add a small supporting line later.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

