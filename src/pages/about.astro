---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
---

<BaseLayout
  title="About — Joseph muema (Placeholder)"
  description="Placeholder About page for Joseph muema’s portfolio website."
>
  <header class="max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-black/60">
      About
    </p>
    <h1 class="mt-3 text-4xl font-bold leading-[0.95] sm:text-5xl">
      Joseph’s story, background, and approach
    </h1>
    <p class="mt-4 text-base leading-relaxed text-black/70 sm:text-lg">
      Placeholder overview. Replace with a short summary of Pete’s professional
      background and what drives his work.
    </p>
  </header>

  <section class="mt-12 grid gap-10 border-t border-black/10 pt-10 sm:mt-16 sm:pt-14">
    <div class="max-w-3xl">
      <h2 class="text-2xl font-bold sm:text-3xl">Background</h2>
      <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
        Placeholder paragraph. Add a few sentences about Joseph’s path, key experiences,
        and what he’s known for.
      </p>
      <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
        Placeholder paragraph. Include a handful of highlights (roles, industries,
        projects, or milestones).
      </p>
    </div>

    <div class="max-w-3xl">
      <h2 class="text-2xl font-bold sm:text-3xl">What Joseph is focused on now</h2>
      <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
        Placeholder paragraph. Describe current priorities, projects, or themes Pete is
        exploring.
      </p>
      <ul class="mt-4 grid gap-2 text-sm text-black/70 sm:text-base">
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent"></span>
          Placeholder focus area #1
        </li>
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent"></span>
          Placeholder focus area #2
        </li>
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent"></span>
          Placeholder focus area #3
        </li>
      </ul>
    </div>
  </section>

  <section class="mt-14 sm:mt-20">
    <NewsletterForm
      heading="Stay in the loop"
      subheading="Placeholder copy. Add a clear reason to subscribe and what readers can expect."
    />
  </section>
</BaseLayout>

