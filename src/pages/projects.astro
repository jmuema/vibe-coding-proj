---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import NewsletterForm from "../components/NewsletterForm.astro";

const projects = [
  {
    title: "Placeholder Project One",
    description:
      "Placeholder description. Replace with a short sentence about what it is and why it matters.",
  },
  {
    title: "Placeholder Project Two",
    description:
      "Placeholder description. Replace with what Pete built, learned, or achieved here.",
  },
  {
    title: "Placeholder Project Three",
    description:
      "Placeholder description. Replace with outcomes, impact, or a crisp value proposition.",
  },
  {
    title: "Placeholder Project Four",
    description:
      "Placeholder description. Add a concrete detail (tech, users, results) later.",
  },
];
---

<BaseLayout
  title="Projects — Joseph muema (Placeholder)"
  description="Placeholder Projects page for Joseph muema’s portfolio website."
>
  <header class="max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-black/60">
      Projects
    </p>
    <h1 class="mt-3 text-4xl font-bold leading-[0.95] sm:text-5xl">
      A few things Joseph has worked on
    </h1>
    <p class="mt-4 text-base leading-relaxed text-black/70 sm:text-lg">
      Placeholder intro. Replace with a sentence about the kinds of projects you’ll
      find here.
    </p>
  </header>

  <section class="mt-12 border-t border-black/10 pt-10 sm:mt-16 sm:pt-14">
    <div class="grid gap-5 sm:grid-cols-2">
      {projects.map((p) => <ProjectCard title={p.title} description={p.description} />)}
    </div>
  </section>

  <section class="mt-14 sm:mt-20">
    <NewsletterForm
      heading="Want weekly notes from Joseph?"
      subheading="Placeholder copy. Add what subscribers get and how often it arrives."
    />
  </section>
</BaseLayout>

